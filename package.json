{
  "name": "rhythm-sass",
  "version": "1.1.3",
  "description": "Sass functions and mixins for precise vertical rhythm and baseline-aligned typography.",
  "main": "./src/rhythm.scss",
  "sass": "./src/rhythm.scss",
  "exports": {
    ".": {
      "sass": "./src/rhythm.scss"
    }
  },
  "scripts": {
    "test": "jest",
    "lint": "stylelint --fix 'src/*.scss'",
    "lint:check": "stylelint 'src/*.scss'",
    "build-examples": "pnpm exec sass ./examples/px-unit/styles.scss:./examples/px-unit/styles.css ./examples/rem-unit/styles.scss:./examples/rem-unit/styles.css --no-source-map",
    "prepare": "husky"
  },
  "keywords": [
    "sass",
    "scss",
    "vertical-rhythm",
    "typography",
    "baseline",
    "baseline-grid",
    "line-height",
    "spacing",
    "layout",
    "sass-library",
    "web-typography"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/p233/rhythm-sass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p233/rhythm-sass.git"
  },
  "bugs": {
    "url": "https://github.com/p233/rhythm-sass/issues"
  },
  "license": "MIT",
  "author": "Peiwen Lu",
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "sass-true": "^10.1.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-prettier": "^5.0.3"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.scss": [
      "stylelint --fix"
    ]
  },
  "files": [
    "src"
  ]
}
